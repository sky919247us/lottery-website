SECRET_KEY="your-secret-key-here"
DATABASE_URL="sqlite:///./scratchcard.db"

# LINE Login 設定
LINE_CHANNEL_ID="你的_LINE_Channel_ID"
LINE_CHANNEL_SECRET="你的_LINE_Channel_Secret"
# 注意：此網址必須與 LINE Developers Console 中的 Callback URL 一致
LINE_REDIRECT_URI="http://localhost:5173/auth/callback"

# JWT 設定
JWT_SECRET_KEY="建議產生一個隨機字串"

# AI 玩法解析（Phase 2）
# 預設使用 Gemini（aistudio.google.com 申請免費 API Key）
AI_PROVIDER="gemini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
